{
  "base": {
    "$type": "dimension",
    "small": { "$value": { "value": 4, "unit": "px" } },
    "medium": { "$value": { "value": 8, "unit": "px" } }
  },
  "spacing": {
    "$extends": "#/base",
    "$type": "dimension",
    "large": { "$value": { "value": 16, "unit": "px" } }
  },
  "compact": {
    "$extends": "{base}",
    "$type": "dimension",
    "medium": { "$value": { "value": 6, "unit": "px" } }
  }
}
