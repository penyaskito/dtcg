{
  "colors": {
    "$type": "color",
    "blue": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0, 0, 1]
      }
    },
    "transparentRed": {
      "$value": {
        "colorSpace": "srgb",
        "components": [1, 0, 0],
        "alpha": 0.5,
        "hex": "#ff0000"
      }
    },
    "withNone": {
      "$value": {
        "colorSpace": "oklab",
        "components": [0.5, "none", 0]
      }
    }
  },
  "strokes": {
    "$type": "strokeStyle",
    "simple": { "$value": "dashed" },
    "custom": {
      "$value": {
        "dashArray": [
          { "value": 4, "unit": "px" },
          { "value": 2, "unit": "px" }
        ],
        "lineCap": "round"
      }
    }
  }
}
