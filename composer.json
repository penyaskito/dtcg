{
    "name": "penyaskito/dtcg",
    "description": "PHP library for parsing, validating, and resolving design tokens in the DTCG (Design Tokens Community Group) format.",
    "type": "library",
    "license": "MIT",
    "keywords": ["design-tokens", "dtcg", "design-system", "tokens"],
    "homepage": "https://github.com/penyaskito/dtcg",
    "authors": [
        {
            "name": "Christian Lopez Espinola",
            "email": "penyaskito@penyaskito.com",
            "homepage": "https://github.com/penyaskito"
        }
    ],
    "require": {
        "php": "^8.3",
        "justinrainbow/json-schema": "^6.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.64",
        "symfony/yaml": "^7.0"
    },
    "suggest": {
        "symfony/yaml": "For loading design token files in YAML format"
    },
    "autoload": {
        "psr-4": {
            "Penyaskito\\Dtcg\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Penyaskito\\Dtcg\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
